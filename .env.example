# Mẫu biến môi trường FE Web — copy sang .env.development / .env.production rồi điền giá trị.
# Mọi biến phải có tiền tố VITE_ mới được Vite expose ra client.

# URL gốc của API backend (kèm /api). Dev: trỏ localhost BE; Prod: URL thật hoặc /api (same-origin).
VITE_API_BASE_URL=http://localhost:5001/api

# Bật Mock Service Worker để FE chạy độc lập không cần BE (task 3.3).
# true = dùng mock (chỉ dev). false / bỏ trống = gọi BE thật (prod).
VITE_ENABLE_MOCK=true
